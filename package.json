{
  "name": "skilleval",
  "version": "0.1.0",
  "description": "Evaluate whether Claude SKILL.md files improve LLM outputs.",
  "bin": {
    "skilleval": "dist/cli.js"
  },
  "scripts": {
    "parse-test": "ts-node src/parse-test.ts",
