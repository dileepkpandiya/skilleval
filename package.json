  },
  "dependencies": {
    "js-yaml": "latest",
    "@types/js-yaml": "latest",
    "@anthropic-ai/sdk": "latest",
    "@google/generative-ai": "latest"
  },
  "devDependencies": {
    "typescript": "latest",
    "ts-node": "latest",
    "@types/node": "latest"
  }
}
