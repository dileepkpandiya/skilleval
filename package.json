{
  "name": "@dileeppandiya/skilleval",
  "version": "0.2.1",
  "description": "Measure whether Claude SKILL.md files improve outputs — blind A/B testing, deterministic assertions, run history, skill comparison, and CI gating in under 2 minutes",
  "bin": {
    "skilleval": "bin/skilleval.js"
  },
  "keywords": [
    "claude",
    "anthropic",
    "skill",
    "skills",
    "llm",
    "llm-evaluation",
    "ai-agents",
    "prompt-testing",
    "evaluation",
    "benchmark",
    "cli",
    "typescript",
    "a-b-testing",
    "ci-cd"
  ],
  "files": [
    "bin/skilleval.js",
    "dist/*.js",
    "!dist/*.test.js",
    "!dist/*-test.js",
    "!dist/*unit-test.js",
    "dist/judges/*.js",
    "samples/",
    "tasks/",
    "calibrations/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "ts-node src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "latest",
    "@types/js-yaml": "latest",
    "commander": "^15.0.0",
    "js-yaml": "latest",
    "json-repair": "npm:jsonrepair@^3.14.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "^3.2.7"
  },
  "license": "MIT"
}
