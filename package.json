{
  "name": "@dileeppandiya/skilleval",
  "version": "0.1.3",
  "description": "Evaluate Claude SKILL.md files with A/B runs, task assertions, and blind LLM judges.",
  "bin": {
    "skilleval": "bin/skilleval.js"
  },
  "keywords": [
    "claude",
    "skills",
    "eval",
    "llm",
    "benchmark",
    "cli"
  ],
  "files": [
    "bin/skilleval.js",
    "dist/*.js",
    "!dist/*.test.js",
    "!dist/*-test.js",
    "!dist/*unit-test.js",
    "dist/judges/*.js",
    "samples/",
    "tasks/",
    "calibrations/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "ts-node src/cli.ts",
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@google/generative-ai": "latest",
    "@types/js-yaml": "latest",
    "commander": "^15.0.0",
    "js-yaml": "latest",
    "json-repair": "npm:jsonrepair@^3.14.1"
  },
  "devDependencies": {
    "@types/node": "latest",
    "ts-node": "latest",
    "typescript": "latest",
    "vitest": "^3.2.7"
  },
  "license": "MIT"
}
